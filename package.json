{
  "name": "open-scaffold",
  "version": "0.3.0",
  "description": "Runtime-neutral scaffold and prompt/artifact CLI for disciplined AI-agent development.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "osc": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "smoke:e2e": "vitest run tests/e2e/lifecycle.test.ts",
    "osc": "tsx src/cli.ts"
  },
  "files": [
    "dist",
    ".osc",
    "docs",
    "AGENTS.md",
    "CLAUDE.md",
    "MISSION.md",
    "ROADMAP.md",
    "README.md",
    "LICENSE",
    "*.sh"
  ],
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  }
}
